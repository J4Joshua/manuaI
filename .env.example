# ─────────────────────────────────────────────────────────────────────────────
# ManuAI — environment template
# Copy to .env and fill in the SECRETS (marked ⚠). Local defaults are already set.
#   cp .env.example .env
# .env is gitignored — never commit real creds.
# Layers map to the skills in .claude/skills/.
# ─────────────────────────────────────────────────────────────────────────────

# ── Moss (retrieval — the offline-critical star)  → skill: moss ───────────────
# ⚠ SECRET. From the Moss portal (https://www.moss.dev). Validated over the network
#   when a session opens, then cached — so authenticate + load_index ONLINE, keep the
#   process alive, THEN go wifi-off. See the moss skill's "OFFLINE ARCHITECTURE REALITY".
MOSS_PROJECT_ID=your-moss-project-id
MOSS_PROJECT_KEY=your-moss-project-key
# Built-in on-device embedder used at BOTH index-time and query-time (parity rule).
# moss-minilm (default, fast) | moss-mediumlm (higher accuracy) | custom (you supply vectors)
MOSS_MODEL_ID=moss-minilm
MOSS_INDEX_NAME=manuals

# ── Unsiloed (PDF parsing — ingestion only, cloud, wifi-on)  → skill: unsiloed ─
# ⚠ SECRET. Sign up at https://unsiloed.ai (or support@unsiloed.ai). Header auth: `api-key`.
UNSILOED_API_KEY=your-unsiloed-api-key
UNSILOED_BASE_URL=https://prod.visionapi.unsiloed.ai

# ── LiveKit (voice orchestration, self-hosted)  → skill: livekit-agents ────────
# Local `livekit-server --dev` defaults below — NOT secret, fine to commit in .example.
# For a pinned box, set your own key:secret in config.yaml and mirror them here.
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ── Local LLM (answer composition)  → skills: qwen, ollama, mlx ────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=qwen2.5:7b-instruct          # use :3b-instruct for the speed/latency build

# ── Local embeddings (ONLY if MOSS_MODEL_ID=custom)  → skills: ollama, mlx ──────
# If you let Moss embed (moss-minilm), you can ignore these. If you supply your own
# vectors, the SAME model+dim MUST be used at index-time and query-time.
EMBED_MODEL=nomic-embed-text:v1.5      # Ollama: 768-dim   (MLX alt: all-MiniLM-L6-v2 = 384-dim)
EMBED_DIM=768

# ── Local STT (push-to-talk)  → skill: whisper-stt ─────────────────────────────
WHISPER_MODEL=mlx-community/whisper-small-mlx   # NOTE: the "-mlx" suffix is required (bare name 404s); bump to whisper-large-v3-turbo-mlx if it mishears error codes. Leave HF_TOKEN blank for anonymous downloads (an empty value sends a broken auth header).
STT_BASE_URL=http://127.0.0.1:9000/v1       # only if you run an OpenAI-compatible Whisper server

# ── Local TTS (spoken answer)  → skill: local-tts ──────────────────────────────
TTS_ENGINE=kokoro                      # kokoro (quality) | piper (ultra-fast fallback)
TTS_VOICE=af_heart
TTS_BASE_URL=http://127.0.0.1:8880/v1  # only if you run a Kokoro/Piper OpenAI-style shim

# ── Apple Silicon / Hugging Face (model downloads + offline)  → skill: mlx ──────
# HF_TOKEN is only needed at SETUP to pull gated models; not required at runtime.
HF_TOKEN=
# Flip to 1 on the edge box at runtime to guarantee no model-download network calls.
HF_HUB_OFFLINE=0

# ── App config ─────────────────────────────────────────────────────────────────
# Default machine scope for retrieval (see data/machines/). cobot-cellA | labeler-line3
MACHINE_ID=labeler-line3
